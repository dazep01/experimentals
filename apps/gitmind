  @keyframes spin { to { transform: rotate(360deg); } }

  /* ===== MOBILE ===== */
  @media (max-width: 768px) {
    :root { --sidebar-w: 0px; }
    #sidebar { position: fixed; left: 0; top: 48px; bottom: 0; z-index: 50; width: 280px; transform: translateX(-100%); transition: transform 0.3s; }
    #sidebar.mobile-open { transform: translateX(0); }
