async function syncRepo(silent = false) {
  if (!State.githubToken || !State.githubUser || !State.githubRepo) {
    if (!silent) {
      UI.toast('Not configured', 'Please set up your GitHub token and repository in Settings.', 'warning');
      showSettings('repo');
    }
    return;
  }

  if (!silent) UI.toast('Syncing', `Fetching ${State.githubUser}/${State.githubRepo}...`, 'info', 2000);
  Terminal.log('info', `Syncing repo: ${State.githubUser}/${State.githubRepo}`);

  try {
    // Get repo info
    const repo = await GitHub.getRepo();
    const defaultBranch = repo.default_branch;

    // Get branches
    const branches = await GitHub.getBranches();
    State.branches = branches;
    if (!State.currentBranch || !branches.includes(State.currentBranch)) {
      State.currentBranch = defaultBranch;
    }
    UI.renderBranches();

    // Get tree
    const flatTree = await GitHub.getTree(State.currentBranch);
    State.repoTree = GitHub.buildTree(flatTree);
    UI.renderTree(State.repoTree, document.getElementById('file-tree'));

    UI.updateStatus(true, `${State.githubUser}/${State.githubRepo}`);
    document.getElementById('repo-pill-text').textContent = `${State.githubUser}/${State.githubRepo}`;
    document.getElementById('repo-pill-icon').textContent = '📦';

    if (!silent) UI.toast('Synced', `Repository loaded — ${flatTree.filter(n=>n.type!=='tree').length} files`, 'success');
    Terminal.log('ok', `Tree loaded: ${flatTree.length} nodes`);

    Storage.save();
  } catch(e) {
    UI.updateStatus(false, 'Error');
    Terminal.log('err', e.message);
    if (!silent) UI.toast('Sync failed', e.message, 'error');
  }
}

async function changeBranch(branch) {
  if (!branch || branch === State.currentBranch) return;
  State.currentBranch = branch;
  Terminal.log('info', `Switching to branch: ${branch}`);
  await syncRepo(true);
  UI.toast('Branch changed', `Now on ${branch}`, 'success', 2000);
  Storage.save();
}

function collapseAll() {
  document.querySelectorAll('.tree-children').forEach(el => el.classList.add('hidden'));
  document.querySelectorAll('.tree-item.folder .tree-icon').forEach(el => el.textContent = '📁');
}

function removeContext(path) {
  State.contextFiles = State.contextFiles.filter(f => f !== path);
  UI.renderContextFiles();
  UI.renderInputContextTags();
  // Update tree selection
  document.querySelectorAll('.tree-item').forEach(el => {
    if (el.dataset.path === path) el.classList.remove('selected');
  });
  Storage.save();
}

function clearContext() {
  State.contextFiles = [];
  UI.renderContextFiles();
  UI.renderInputContextTags();
  document.querySelectorAll('.tree-item.selected').forEach(el => el.classList.remove('selected'));
  Storage.save();
}

