  .settings-nav-item { padding: 7px 10px; border-radius: var(--radius-xs); cursor: pointer; font-size: 12px; color: var(--text-1); display: flex; align-items: center; gap: 8px; transition: var(--transition); }
  .settings-nav-item:hover { background: var(--bg-glass); color: var(--text-0); }
  .settings-nav-item.active { background: var(--accent-dim); color: var(--accent); }
  .settings-layout { display: flex; gap: 16px; }
  .settings-sidebar { width: 140px; flex-shrink: 0; }
  .settings-content { flex: 1; }

  /* Key badge */
  .key-badge { background: var(--bg-2); border: 1px solid var(--border); border-radius: 4px; padding: 1px 5px; font-family: var(--font-mono); font-size: 10px; color: var(--text-2); }

