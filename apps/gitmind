              ? '→ Get key at <a href="https://aistudio.google.com/app/apikey" target="_blank" style="color:var(--accent)">Google AI Studio</a>'
              : '→ Get key at <a href="https://console.groq.com/keys" target="_blank" style="color:var(--accent)">Groq Console</a>'
            }
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Model Name</label>
          <input class="form-input" id="s-model" value="${State.aiModel}" placeholder="${State.provider==='gemini'?'gemini-2.0-flash':'llama-3.3-70b-versatile'}" />
          <div class="form-hint" id="model-hint">
            ${State.provider==='gemini'
              ? 'Recommended: gemini-2.0-flash, gemini-1.5-pro'
              : 'Recommended: llama-3.3-70b-versatile, mixtral-8x7b-32768'
            }
          </div>
        </div>
      </div>
    `;
  }

  if (tab === 'repo') {
    return `
      <div class="form-section">
        <div class="form-section-title">GitHub Repository</div>
        <div class="form-group">
          <label class="form-label">Personal Access Token</label>
          <input class="form-input" type="password" id="s-gh-token" value="${State.githubToken}" placeholder="ghp_xxxxxxxxxxxx" autocomplete="off" />
          <div class="form-hint">→ Generate at GitHub → Settings → Developer settings → <a href="https://github.com/settings/tokens" target="_blank" style="color:var(--accent)">Personal access tokens</a>. Requires <strong>repo</strong> scope.</div>
        </div>
        <div class="form-group">
          <label class="form-label">GitHub Username</label>
          <input class="form-input" id="s-gh-user" value="${State.githubUser}" placeholder="your-username" />
        </div>
        <div class="form-group">
          <label class="form-label">Repository Name</label>
          <input class="form-input" id="s-gh-repo" value="${State.githubRepo}" placeholder="my-repo" />
        </div>
        <button class="btn-primary" style="margin-top:4px;" onclick="saveSettingsAndSync()">Save & Sync Repository</button>
      </div>
    `;
  }

  if (tab === 'security') {
    const info = Storage.getExpiryInfo();
    return `
      <div class="form-section">
        <div class="form-section-title">Session Security</div>
        ${info ? `
          <div style="background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius-xs);padding:12px;margin-bottom:16px;">
            <div style="font-size:12px;color:var(--text-1);">
              <div style="margin-bottom:4px;">🔒 Credentials encrypted in localStorage</div>
              <div style="margin-bottom:4px;">⏱ Session expires in: <strong style="color:${info.warning?'var(--yellow)':'var(--green)'};">${info.days}d ${info.hours}h</strong></div>
              <div>📅 Auto-cleared after ${EXPIRY_DAYS} days</div>
            </div>
          </div>
        ` : '<div style="font-size:12px;color:var(--text-2);margin-bottom:12px;">No active session stored.</div>'}
        <div class="form-group">
          <label class="form-label">Actions</label>
          <div style="display:flex;flex-direction:column;gap:8px;">
            <button class="btn-secondary" onclick="exportSettings()">⬆ Export settings (encrypted)</button>
            <button class="btn-primary btn-danger" onclick="clearAllCredentials()" style="background:var(--red);border-color:var(--red);">🗑 Clear all credentials</button>
          </div>
        </div>
        <div class="form-hint">All credentials are stored only in your browser's localStorage. They are never sent to any server other than the AI and GitHub APIs.</div>
      </div>
    `;
  }
  return '';
}

function selectProvider(p) {
  State.provider = p;
  document.querySelectorAll('.provider-tab').forEach((el, i) => {
    el.classList.toggle('active', ['gemini','groq'][i] === p);
  });
  // Update placeholders and hints
  const modelInput = document.getElementById('s-model');
  const modelHint = document.getElementById('model-hint');
  const apiHint = document.querySelector('.form-hint');
  if (modelInput) modelInput.placeholder = p === 'gemini' ? 'gemini-2.0-flash' : 'llama-3.3-70b-versatile';
  if (modelHint) modelHint.textContent = p === 'gemini' ? 'Recommended: gemini-2.0-flash, gemini-1.5-pro' : 'Recommended: llama-3.3-70b-versatile, mixtral-8x7b-32768';
}

function saveSettings() {
  // Save AI settings
  const apiKey = document.getElementById('s-api-key');
  const model = document.getElementById('s-model');
  const ghToken = document.getElementById('s-gh-token');
  const ghUser = document.getElementById('s-gh-user');
  const ghRepo = document.getElementById('s-gh-repo');

  if (apiKey) State.apiKey = apiKey.value.trim();
  if (model) State.aiModel = model.value.trim();
  if (ghToken) State.githubToken = ghToken.value.trim();
  if (ghUser) State.githubUser = ghUser.value.trim();
  if (ghRepo) State.githubRepo = ghRepo.value.trim();

  Storage.save();
  UI.updateExpiryBadge();
  closeSettings();
  UI.toast('Settings saved', 'Your configuration has been saved.', 'success');
}

async function saveSettingsAndSync() {
  saveSettings();
  document.getElementById('settings-overlay')?.remove();
  await syncRepo();
}

function closeSettings() {
  document.getElementById('settings-overlay')?.remove();
}

function clearAllCredentials() {
  if (!confirm('Clear all credentials? This will log you out.')) return;
  Storage.clear();
  State.apiKey = '';
  State.githubToken = '';
  State.githubUser = '';
  State.githubRepo = '';
  State.provider = 'gemini';
  State.aiModel = '';
  State.connected = false;
  UI.updateStatus(false, 'Not connected');
  document.getElementById('repo-pill-text').textContent = 'No repo connected';
  closeSettings();
  UI.toast('Cleared', 'All credentials removed', 'success');
}

function exportSettings() {
  const data = {
    provider: State.provider,
    aiModel: State.aiModel,
    githubUser: State.githubUser,
    githubRepo: State.githubRepo,
    note: 'Tokens not exported for security'
  };
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'gitmind-settings.json';
  a.click(); URL.revokeObjectURL(url);
}

// ============================================================
// ===== TERMINAL =====
// ============================================================
function toggleTerminal(forceOpen) {
  const wrapper = document.getElementById('terminal-wrapper');
  const btn = document.getElementById('terminal-toggle');
  State.terminalOpen = forceOpen !== undefined ? forceOpen : !State.terminalOpen;
  wrapper.classList.toggle('open', State.terminalOpen);
  btn.classList.toggle('terminal-open', State.terminalOpen);
  btn.textContent = State.terminalOpen ? '▾ LOGS' : '▸ LOGS';
  if (State.terminalOpen) {
    const out = document.getElementById('terminal-output');
    out.scrollTop = out.scrollHeight;
  }
}

function clearTerminal() {
  Terminal.clear();
}

// ============================================================
// ===== SIDEBAR RESIZE =====
// ============================================================
(function initResizer() {
  const resizer = document.getElementById('resizer');
  const sidebar = document.getElementById('sidebar');
  let dragging = false, startX = 0, startW = 0;

  resizer.addEventListener('mousedown', e => {
    dragging = true;
    startX = e.clientX;
    startW = sidebar.offsetWidth;
    resizer.classList.add('dragging');
    document.body.style.cursor = 'col-resize';
    document.body.style.userSelect = 'none';
  });

  document.addEventListener('mousemove', e => {
    if (!dragging) return;
    const newW = Math.max(160, Math.min(500, startW + e.clientX - startX));
    sidebar.style.width = newW + 'px';
  });

  document.addEventListener('mouseup', () => {
    if (!dragging) return;
    dragging = false;
    resizer.classList.remove('dragging');
    document.body.style.cursor = '';
    document.body.style.userSelect = '';
  });
})();

// Sidebar toggle
document.getElementById('sidebar-toggle').addEventListener('click', () => {
  const sidebar = document.getElementById('sidebar');
  State.sidebarOpen = !State.sidebarOpen;
  if (window.innerWidth <= 768) {
    sidebar.classList.toggle('mobile-open', State.sidebarOpen);
  } else {
    sidebar.classList.toggle('collapsed', !State.sidebarOpen);
  }
});

// ============================================================
// ===== INPUT HANDLING =====
// ============================================================
const chatInput = document.getElementById('chat-input');
chatInput.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    handleSend();
  }
});
chatInput.addEventListener('input', () => autoResizeInput(chatInput));

function autoResizeInput(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 140) + 'px';
}

// ============================================================
// ===== MARKDOWN RENDERER =====
// ============================================================
function renderMarkdown(text) {
  if (!text) return '';
  let html = escapeHtml(text);

  // Code blocks
  html = html.replace(/```(\w*)\n?([\s\S]*?)```/g, (_, lang, code) =>
    `<pre><code class="lang-${lang}">${code.trim()}</code></pre>`
  );
  // Inline code
  html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
  // Bold
  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  // Italic
  html = html.replace(/(?<!\*)\*([^*]+)\*(?!\*)/g, '<em>$1</em>');
  // Headers
  html = html.replace(/^### (.+)$/gm, '<h3>$1</h3>');
  html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');
  html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');
  // HR
  html = html.replace(/^---$/gm, '<hr>');
  // Blockquote
  html = html.replace(/^&gt; (.+)$/gm, '<blockquote>$1</blockquote>');
  // Unordered list
  html = html.replace(/^[\-\*] (.+)$/gm, '<li>$1</li>');
  html = html.replace(/(<li>[\s\S]+?<\/li>)/g, '<ul>$1</ul>');
  // Ordered list
  html = html.replace(/^\d+\. (.+)$/gm, '<li>$1</li>');
  // Links
  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
  // Newlines to <br>
  html = html.replace(/\n(?!<\/?(ul|ol|li|h[123]|pre|blockquote|hr))/g, '<br>');

  return html;
}

// ============================================================
// ===== UTILS =====
// ============================================================
function escapeHtml(str) {
  if (typeof str !== 'string') return '';
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function getFileIcon(name) {
  const ext = name.split('.').pop()?.toLowerCase();
  const icons = {
    js: '🟨', ts: '🔷', jsx: '⚛', tsx: '⚛',
    html: '🌐', css: '🎨', scss: '🎨', sass: '🎨',
    json: '📋', md: '📝', txt: '📄',
    py: '🐍', rb: '💎', go: '🔵', rs: '🦀',
    java: '☕', kt: '🔷', swift: '🍊',
    php: '🐘', sh: '⬛', yaml: '⚙', yml: '⚙',
    toml: '⚙', env: '🔒', gitignore: '👻',
    png: '🖼', jpg: '🖼', jpeg: '🖼', svg: '🖼', gif: '🖼',
    pdf: '📕', zip: '📦', tar: '📦',
    dockerfile: '🐳', lock: '🔒',
  };
  return icons[ext] || (name.startsWith('.') ? '⚙' : '📄');
}

// ============================================================
// ===== KEYBOARD SHORTCUTS =====
// ============================================================
document.addEventListener('keydown', e => {
  // Ctrl/Cmd + K = focus chat
  if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
    e.preventDefault();
    document.getElementById('chat-input').focus();
  }
  // Ctrl + Shift + L = toggle terminal
  if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'L') {
    e.preventDefault();
    toggleTerminal();
  }
  // Ctrl + , = settings
  if ((e.ctrlKey || e.metaKey) && e.key === ',') {
    e.preventDefault();
    showSettings('ai');
  }
  // Escape = close modals
  if (e.key === 'Escape') {
    const overlay = document.querySelector('.modal-overlay');
    if (overlay) overlay.remove();
  }
});

// ============================================================
// ===== RESTORE CHAT HISTORY =====
// ============================================================
function restoreChatHistory() {
  const history = State.chatHistory;
  if (!history || history.length === 0) return;

  const chatArea = document.getElementById('chat-area');
  const welcome = document.getElementById('welcome');
  if (welcome) welcome.remove();

  // Only restore last 30 messages
  const recent = history.slice(-30);
  for (const entry of recent) {
    if (entry.role === 'user') {
      addMessage('user', entry.content);
      State.messages.push({ role: 'user', content: entry.content });
    } else if (entry.role === 'ai') {
      addMessage('ai', entry.content);
      State.messages.push({ role: 'assistant', content: entry.content });
    } else if (entry.role === 'system') {
      addMessage('system', entry.content);
    }
  }

  if (recent.length > 0) {
    const divider = document.createElement('div');
    divider.style.cssText = 'text-align:center;font-size:10px;color:var(--text-3);padding:8px 0;';
    divider.textContent = '— restored from previous session —';
    chatArea.insertBefore(divider, chatArea.children[0]);
    chatArea.scrollTop = chatArea.scrollHeight;
  }
}

// ============================================================
// ===== INITIALIZE =====
// ============================================================
async function init() {
  Terminal.log('info', `GitMind v${APP_VERSION} initializing...`);

  // Load stored state
  const loaded = Storage.load();
  if (loaded) {
    Terminal.log('ok', 'Session loaded from storage');
    UI.updateExpiryBadge();
  }

  // Restore chat
  if (State.chatHistory.length > 0) {
    restoreChatHistory();
  }

  // Render context files
  UI.renderContextFiles();
  UI.renderInputContextTags();

  // Auto-sync if configured
  if (State.githubToken && State.githubUser && State.githubRepo) {
    UI.updateStatus(false, 'Syncing...');
    await syncRepo(true);
    Terminal.log('ok', 'Auto-sync complete');
  } else {
    UI.updateStatus(false, 'Not connected');
    Terminal.log('warn', 'No repo configured — open Settings to get started');
  }

  // First time guidance
  if (!loaded) {
    setTimeout(() => {
      UI.toast('Welcome to GitMind!', 'Open Settings (⚙) to connect your GitHub repo and AI provider.', 'info', 6000);
    }, 500);
  }

  Terminal.log('ok', 'GitMind ready');
}

// Start app
init();
</script>
