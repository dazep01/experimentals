async function handleSend() {
  const input = document.getElementById('chat-input');
  const text = input.value.trim();
  if (!text || State.isThinking) return;

  // Handle commands
  if (text === '/exec' || text === '/eksekusi') {
    input.value = '';
    autoResizeInput(input);
    if (State.pendingOperation) await executeOperation();
    else UI.toast('No pending operation', 'There is no operation waiting to be executed.', 'warning');
    return;
  }
  if (text === '/cancel') {
    input.value = '';
    autoResizeInput(input);
    cancelOperation();
    return;
  }
  if (text === '/clear') {
    input.value = '';
    autoResizeInput(input);
    clearChat();
    return;
  }

  input.value = '';
  autoResizeInput(input);

  // Add user message
  addMessage('user', text);
  State.chatHistory.push({ role: 'user', content: text, ts: Date.now() });

  // Check API key
  if (!State.apiKey) {
    addMessage('ai', '⚠️ **No AI API key configured.**\n\nPlease go to **Settings** → **AI Provider** and add your API key to start chatting.\n\nI support:\n- **Gemini** (Google AI Studio)\n- **Groq** (ultra-fast inference)');
    return;
  }

  State.isThinking = true;
  document.getElementById('send-btn').disabled = true;

  const typingEl = addTypingIndicator();

  try {
    Terminal.log('info', `User: ${text.slice(0, 80)}${text.length > 80 ? '...' : ''}`);
    const response = await AI.generateResponse(text);
    removeTypingIndicator();

    // Parse operation plan
    const plan = CommandParser.parseOperationPlan(response);
    const cleanText = CommandParser.stripPlan(response);

    const msgEl = addMessage('ai', cleanText || '');
    State.chatHistory.push({ role: 'ai', content: cleanText, ts: Date.now() });

    if (plan) {
      State.pendingOperation = plan;
      addOperationPreview(plan, msgEl);
      Terminal.log('info', `Operation plan received: ${plan.operations?.length || 0} operation(s)`);
    }

  } catch(e) {
    removeTypingIndicator();
    addMessage('ai', `❌ **Error:** ${e.message}\n\nPlease check your API key and provider settings.`);
    Terminal.log('err', e.message);
    UI.toast('AI Error', e.message, 'error');
  } finally {
    State.isThinking = false;
    document.getElementById('send-btn').disabled = false;
  }

  Storage.save();
}

async function executeOperation() {
  if (!State.pendingOperation) return;
  if (!State.githubToken) {
    UI.toast('No GitHub token', 'Please configure your GitHub token in Settings.', 'error');
    return;
  }

  const plan = State.pendingOperation;
  State.pendingOperation = null;

  // Disable execute btn
  const execBtn = document.getElementById('exec-btn');
  if (execBtn) { execBtn.disabled = true; execBtn.textContent = '⟳ Executing...'; }

  addMessage('system', `⚡ Executing ${plan.operations?.length || 0} operation(s)...`);
  Terminal.log('exec', 'Starting execution...');

  try {
    const results = await Executor.execute(plan, plan.commitMessage);
    const successCount = results.filter(r => r.success).length;

    // Build result summary
    let summary = `✅ **Execution complete!** ${successCount}/${results.length} operation(s) succeeded.\n\n`;
    for (const r of results) {
      if (r.success) {
        summary += `- ✓ **${r.op.op}** \`${r.op.path || r.op.name || ''}\`\n`;
        // If read op, show content snippet
        if (r.op.op === 'read' && r.result?.content) {
          const preview = r.result.content.slice(0, 300);
          summary += `\n\`\`\`\n${preview}${r.result.content.length > 300 ? '\n...(truncated)' : ''}\n\`\`\`\n`;
        }
      } else {
        summary += `- ✗ **${r.op.op}** \`${r.op.path || r.op.name || ''}\` — ${r.error}\n`;
      }
    }

    addMessage('ai', summary);
    State.chatHistory.push({ role: 'ai', content: summary, ts: Date.now() });
    UI.toast('Execution complete', `${successCount} operation(s) succeeded`, 'success');
    Terminal.log('ok', 'Execution complete');

    // Track changes
    for (const r of results) {
      if (!r.success) continue;
      if (['create', 'update'].includes(r.op.op)) {
        const existing = State.changedFiles.find(c => c.path === r.op.path);
        if (existing) existing.status = 'M';
        else State.changedFiles.push({ path: r.op.path, status: r.op.op === 'create' ? 'A' : 'M' });
      } else if (r.op.op === 'delete') {
        State.changedFiles.push({ path: r.op.path, status: 'D' });
      }
    }
    UI.renderChangedFiles();

  } catch(e) {
    addMessage('ai', `❌ **Execution failed:** ${e.message}\n\nCheck the logs for details.`);
    UI.toast('Execution failed', e.message, 'error');
    Terminal.log('err', 'Execution failed: ' + e.message);
  }

  Storage.save();
}

function cancelOperation() {
  if (State.pendingOperation) {
    State.pendingOperation = null;
    addMessage('system', '✕ Operation cancelled.');
    const execBtn = document.getElementById('exec-btn');
    if (execBtn) { execBtn.disabled = true; execBtn.textContent = 'Cancelled'; }
    UI.toast('Operation cancelled', '', 'info');
  }
}

