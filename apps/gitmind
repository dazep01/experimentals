const UI = {
  toast(title, msg, type = 'info', duration = 4000) {
    const icons = { success: '✓', error: '✗', warning: '⚠', info: 'ℹ' };
    const container = document.getElementById('toast-container');
    const el = document.createElement('div');
    el.className = `toast ${type}`;
    el.innerHTML = `<span class="toast-icon">${icons[type]||'ℹ'}</span><div class="toast-body"><div class="toast-title">${escapeHtml(title)}</div>${msg ? `<div class="toast-msg">${escapeHtml(msg)}</div>` : ''}</div>`;
    container.appendChild(el);
    setTimeout(() => {
      el.classList.add('removing');
      setTimeout(() => el.remove(), 300);
    }, duration);
  },

  updateStatus(connected, text) {
    State.connected = connected;
    document.getElementById('status-dot').className = `status-dot ${connected ? 'connected' : ''}`;
    document.getElementById('status-text').textContent = text;
    if (State.githubUser && State.githubRepo) {
      document.getElementById('repo-pill-text').textContent = `${State.githubUser}/${State.githubRepo}`;
      document.getElementById('repo-pill-icon').textContent = '📦';
    }
  },

  renderTree(nodes, container, depth = 0) {
    container.innerHTML = '';
    if (!nodes || nodes.length === 0) {
      container.innerHTML = '<div class="tree-empty">Empty repository</div>';
      return;
    }
    UI._renderNodes(nodes, container);
  },

  _renderNodes(nodes, container) {
    for (const node of nodes) {
      const wrapper = document.createElement('div');
      wrapper.className = 'tree-node';

      const item = document.createElement('div');
      item.className = `tree-item ${node.type === 'tree' ? 'folder' : 'file'}`;
      item.dataset.path = node.path;
      item.dataset.type = node.type;

      const icon = node.type === 'tree' ? '📁' : getFileIcon(node.name);
      item.innerHTML = `<span class="tree-icon">${icon}</span>${escapeHtml(node.name)}`;

      if (node.type === 'tree') {
        const children = document.createElement('div');
        children.className = 'tree-children hidden';
        let expanded = false;

        item.addEventListener('click', (e) => {
          e.stopPropagation();
          expanded = !expanded;
          children.classList.toggle('hidden', !expanded);
          item.querySelector('.tree-icon').textContent = expanded ? '📂' : '📁';
        });

        wrapper.appendChild(item);
        if (node.children && node.children.length > 0) {
          UI._renderNodes(node.children, children);
          wrapper.appendChild(children);
        }
      } else {
        item.addEventListener('click', (e) => {
          e.stopPropagation();
          // Toggle context selection
          const p = node.path;
          const idx = State.contextFiles.indexOf(p);
          if (idx === -1) {
            State.contextFiles.push(p);
            item.classList.add('selected');
          } else {
            State.contextFiles.splice(idx, 1);
            item.classList.remove('selected');
          }
          UI.renderContextFiles();
          UI.renderInputContextTags();
          Storage.save();
        });

        // Mark selected
        if (State.contextFiles.includes(node.path)) {
          item.classList.add('selected');
        }
        wrapper.appendChild(item);
      }

      container.appendChild(wrapper);
    }
  },

  renderContextFiles() {
    const el = document.getElementById('context-files');
    if (State.contextFiles.length === 0) {
      el.innerHTML = '<div class="tree-empty" style="padding:8px 0;">No files selected</div>';
      return;
    }
    el.innerHTML = State.contextFiles.map(f => `
      <div class="ctx-file">
        <span>${getFileIcon(f)}</span>
        <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${escapeHtml(f)}</span>
        <span class="ctx-remove" onclick="removeContext('${escapeHtml(f)}')">✕</span>
      </div>
    `).join('');
  },

  renderInputContextTags() {
    const el = document.getElementById('input-context-tags');
    if (State.contextFiles.length === 0) { el.innerHTML = ''; return; }
    el.innerHTML = State.contextFiles.map(f =>
      `<div class="ctx-tag">${getFileIcon(f)} ${escapeHtml(f.split('/').pop())}</div>`
    ).join('');
  },

  renderChangedFiles() {
    const el = document.getElementById('changed-files');
    if (State.changedFiles.length === 0) {
      el.innerHTML = '<div class="tree-empty" style="padding:8px 0;">No changes</div>';
      return;
    }
    el.innerHTML = State.changedFiles.map(f => `
      <div class="changed-file">
        <span class="cf-badge ${f.status}">${f.status}</span>
        <span style="font-size:11px;color:var(--text-1);overflow:hidden;text-overflow:ellipsis;">${escapeHtml(f.path)}</span>
      </div>
    `).join('');
  },

  renderBranches() {
    const sel = document.getElementById('branch-select');
    sel.innerHTML = State.branches.map(b =>
      `<option value="${escapeHtml(b)}" ${b === State.currentBranch ? 'selected' : ''}>${escapeHtml(b)}</option>`
    ).join('');
  },

  updateExpiryBadge() {
    const info = Storage.getExpiryInfo();
    const badge = document.getElementById('expiry-badge');
    if (!info || !State.apiKey) { badge.style.display = 'none'; return; }
    badge.style.display = 'flex';
    badge.className = `expiry-badge${info.warning ? ' warning' : ''}`;
    badge.innerHTML = `${info.warning ? '⚠' : '🔒'} Session expires in ${info.days}d ${info.hours}h`;
  }
};

