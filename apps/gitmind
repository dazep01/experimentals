<script>
'use strict';
// ============================================================
// ===== STATE =====
// ============================================================
const APP_VERSION = '1.0.0';
const STORAGE_KEY = 'gitmind_v1';
const EXPIRY_DAYS = 7;

const State = {
  // Settings
  provider: 'gemini',
  aiModel: '',
  apiKey: '',
  githubToken: '',
  githubUser: '',
  githubRepo: '',
  // Runtime
  connected: false,
  currentBranch: '',
  branches: [],
  repoTree: [],
  contextFiles: [],
  changedFiles: [],
  // Chat
  chatHistory: [],
  messages: [], // [{role,content}] for AI
  pendingOperation: null,
  isThinking: false,
  // Terminal
  terminalOpen: false,
  // Sidebar
  sidebarOpen: true,
};

// ============================================================
// ===== STORAGE =====
// ============================================================
const Storage = {
  save() {
    const data = {
      ts: Date.now(),
      provider: State.provider,
      aiModel: State.aiModel,
      apiKey: State.apiKey,
      githubToken: State.githubToken,
      githubUser: State.githubUser,
      githubRepo: State.githubRepo,
      chatHistory: State.chatHistory.slice(-100),
      contextFiles: State.contextFiles,
      currentBranch: State.currentBranch,
    };
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
  },
  load() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return false;
      const data = JSON.parse(raw);
      // Check expiry
      if (Date.now() - data.ts > EXPIRY_DAYS * 24 * 60 * 60 * 1000) {
        this.clear();
        UI.toast('Session expired', 'Your credentials have been cleared after 7 days for security.', 'warning');
        return false;
      }
      State.provider = data.provider || 'gemini';
      State.aiModel = data.aiModel || '';
      State.apiKey = data.apiKey || '';
      State.githubToken = data.githubToken || '';
      State.githubUser = data.githubUser || '';
      State.githubRepo = data.githubRepo || '';
      State.chatHistory = data.chatHistory || [];
      State.contextFiles = data.contextFiles || [];
      State.currentBranch = data.currentBranch || '';
      return true;
    } catch (e) { return false; }
  },
  clear() {
    localStorage.removeItem(STORAGE_KEY);
  },
  getExpiryInfo() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      const data = JSON.parse(raw);
      const elapsed = Date.now() - data.ts;
      const remaining = EXPIRY_DAYS * 24 * 60 * 60 * 1000 - elapsed;
      const days = Math.floor(remaining / (24*60*60*1000));
      const hours = Math.floor((remaining % (24*60*60*1000)) / (60*60*1000));
      return { days, hours, warning: days < 1 };
    } catch { return null; }
  }
};

// ============================================================
// ===== AI PROVIDER ABSTRACTION =====
// ============================================================
const AI = {
  buildSystemPrompt() {
    const treeStr = State.repoTree.length > 0
      ? 'Repository structure:\n' + AI.treeToString(State.repoTree, '')
      : 'No repository connected yet.';

    const ctxStr = State.contextFiles.length > 0
      ? '\nSelected context files:\n' + State.contextFiles.map(f => `  - ${f}`).join('\n')
      : '';

    const branchStr = State.currentBranch ? `\nActive branch: ${State.currentBranch}` : '';
    const repoStr = (State.githubUser && State.githubRepo)
      ? `\nRepository: ${State.githubUser}/${State.githubRepo}` : '';

    return `You are GitMind, an AI-powered GitHub workspace assistant. You help users manage their GitHub repositories through natural language.

${repoStr}${branchStr}

${treeStr}${ctxStr}

CAPABILITIES:
- Read file contents from the repository
- Create new files with specified content
- Update/edit existing files
- Delete files
- Create branches
- List repository contents

IMPORTANT RULES:
1. NEVER auto-execute operations. Always show a preview first and ask for approval.
2. For any file operation, generate a structured operation plan.
3. Use this EXACT format when proposing operations:

---OPERATION_PLAN---
{
  "description": "Brief description of what will be done",
  "operations": [
    {"op": "create", "path": "folder/file.txt", "content": "file content here"},
    {"op": "update", "path": "existing.txt", "content": "new content"},
    {"op": "delete", "path": "old-file.txt"},
    {"op": "create_branch", "name": "feature/new-feature", "from": "main"},
    {"op": "read", "path": "some-file.txt"}
  ],
  "commitMessage": "feat: description of changes"
}
---END_PLAN---

4. After showing the plan, add a note like: "Type **/exec** or click **Execute** to proceed, or **/cancel** to abort."
5. For read operations (just viewing files), you can describe what you'd see or ask me to fetch it.
6. Be concise, professional, and helpful.
7. If no repo is connected, guide the user to connect one via Settings.
8. Respond in the same language the user writes in.
9. For general questions (not operations), respond normally without an operation plan.
10. Suggest commit messages in conventional commits format when applicable.`;
  },

  treeToString(nodes, indent) {
    let str = '';
    for (const node of nodes) {
      if (node.type === 'tree') {
        str += `${indent}${node.name}/\n`;
        if (node.children) str += AI.treeToString(node.children, indent + '  ');
      } else {
        str += `${indent}${node.name}\n`;
      }
    }
    return str;
  },

  async generateResponse(userMessage) {
    if (!State.apiKey) throw new Error('No API key configured. Please go to Settings.');

    State.messages.push({ role: 'user', content: userMessage });
    const systemPrompt = AI.buildSystemPrompt();

    if (State.provider === 'gemini') {
      return await AI.callGemini(systemPrompt, State.messages);
    } else if (State.provider === 'groq') {
      return await AI.callGroq(systemPrompt, State.messages);
    }
    throw new Error('Unknown AI provider: ' + State.provider);
  },

  async callGemini(systemPrompt, messages) {
    const model = State.aiModel || 'gemini-2.0-flash';
    const url = `https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${State.apiKey}`;

    // Build Gemini-compatible contents
    const contents = messages.map(m => ({
      role: m.role === 'assistant' ? 'model' : 'user',
      parts: [{ text: m.content }]
    }));

    const body = {
      systemInstruction: { parts: [{ text: systemPrompt }] },
      contents,
      generationConfig: {
        temperature: 0.7,
        maxOutputTokens: 4096,
      }
    };

    Terminal.log('info', `[Gemini] Calling ${model}...`);
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });

    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      const msg = err.error?.message || `HTTP ${res.status}`;
      throw new Error(`Gemini API error: ${msg}`);
    }

    const data = await res.json();
    const text = data.candidates?.[0]?.content?.parts?.[0]?.text || '';
    if (!text) throw new Error('Empty response from Gemini');

    State.messages.push({ role: 'assistant', content: text });
    return text;
  },

  async callGroq(systemPrompt, messages) {
    const model = State.aiModel || 'llama-3.3-70b-versatile';
    const url = 'https://api.groq.com/openai/v1/chat/completions';

    const msgs = [
      { role: 'system', content: systemPrompt },
      ...messages
    ];

    Terminal.log('info', `[Groq] Calling ${model}...`);
    const res = await fetch(url, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${State.apiKey}`,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        model,
        messages: msgs,
        temperature: 0.7,
        max_tokens: 4096,
      })
    });

    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      const msg = err.error?.message || `HTTP ${res.status}`;
      throw new Error(`Groq API error: ${msg}`);
    }

    const data = await res.json();
    const text = data.choices?.[0]?.message?.content || '';
    if (!text) throw new Error('Empty response from Groq');

    State.messages.push({ role: 'assistant', content: text });
    return text;
  }
};

// ============================================================
// ===== GITHUB API =====
// ============================================================
const GitHub = {
  baseUrl: 'https://api.github.com',

  headers() {
    return {
      'Authorization': `token ${State.githubToken}`,
      'Accept': 'application/vnd.github+json',
      'X-GitHub-Api-Version': '2022-11-28',
    };
  },

  async request(method, path, body) {
    const url = `${this.baseUrl}${path}`;
    Terminal.log('exec', `${method} ${path}`);
    const res = await fetch(url, {
      method,
      headers: { ...this.headers(), 'Content-Type': 'application/json' },
      body: body ? JSON.stringify(body) : undefined,
    });

    const data = await res.json().catch(() => ({}));

    if (!res.ok) {
      const msg = data.message || `HTTP ${res.status}`;
      Terminal.log('err', `Error: ${msg}`);
      throw new Error(`GitHub API: ${msg}`);
    }

    Terminal.log('ok', `Response: ${res.status}`);
    return data;
  },

  async getRepo() {
    return this.request('GET', `/repos/${State.githubUser}/${State.githubRepo}`);
  },

  async getBranches() {
    const data = await this.request('GET', `/repos/${State.githubUser}/${State.githubRepo}/branches?per_page=50`);
    return data.map(b => b.name);
  },

  async getTree(branch) {
    const data = await this.request('GET', `/repos/${State.githubUser}/${State.githubRepo}/git/trees/${branch}?recursive=1`);
    return data.tree || [];
  },

  async getFileContent(path, branch) {
    const ref = branch || State.currentBranch;
    const data = await this.request('GET', `/repos/${State.githubUser}/${State.githubRepo}/contents/${path}?ref=${ref}`);
    return data;
  },

  async createOrUpdateFile(path, content, message, sha, branch) {
    const encoded = btoa(unescape(encodeURIComponent(content)));
    const body = {
      message,
      content: encoded,
      branch: branch || State.currentBranch,
    };
    if (sha) body.sha = sha;
    return this.request('PUT', `/repos/${State.githubUser}/${State.githubRepo}/contents/${path}`, body);
  },

  async deleteFile(path, message, sha, branch) {
    const body = {
      message,
      sha,
      branch: branch || State.currentBranch,
    };
    return this.request('DELETE', `/repos/${State.githubUser}/${State.githubRepo}/contents/${path}`, body);
  },

  async createBranch(name, fromBranch) {
    // Get SHA of source branch
    const ref = await this.request('GET', `/repos/${State.githubUser}/${State.githubRepo}/git/ref/heads/${fromBranch || State.currentBranch}`);
    const sha = ref.object.sha;
    return this.request('POST', `/repos/${State.githubUser}/${State.githubRepo}/git/refs`, {
      ref: `refs/heads/${name}`,
      sha
    });
  },

  buildTree(flatTree) {
    const root = [];
    const map = {};

    // Sort: folders first
    const sorted = [...flatTree].sort((a, b) => {
      if (a.type !== b.type) return a.type === 'tree' ? -1 : 1;
      return a.path.localeCompare(b.path);
    });

    for (const item of sorted) {
      const parts = item.path.split('/');
      const name = parts[parts.length - 1];
      const node = { name, path: item.path, type: item.type === 'tree' ? 'tree' : 'blob', sha: item.sha, children: [] };

      if (parts.length === 1) {
        root.push(node);
      } else {
        const parentPath = parts.slice(0, -1).join('/');
        if (!map[parentPath]) map[parentPath] = { children: [] };
        if (!map[parentPath].children) map[parentPath].children = [];
        map[parentPath].children.push(node);
      }
      map[item.path] = node;
    }

    // Link children to parents
    for (const [path, node] of Object.entries(map)) {
      const parts = path.split('/');
      if (parts.length > 1) {
        const parentPath = parts.slice(0, -1).join('/');
        if (map[parentPath] && !map[parentPath].children.includes(node)) {
          // already handled above
        }
      }
    }

    return root;
  }
};

// ============================================================
// ===== COMMAND PARSER =====
// ============================================================
const CommandParser = {
  parseOperationPlan(aiText) {
    const match = aiText.match(/---OPERATION_PLAN---\s*([\s\S]*?)\s*---END_PLAN---/);
    if (!match) return null;
    try {
      return JSON.parse(match[1].trim());
    } catch(e) {
      Terminal.log('err', 'Failed to parse operation plan: ' + e.message);
      return null;
    }
  },

  stripPlan(text) {
    return text.replace(/---OPERATION_PLAN---[\s\S]*?---END_PLAN---/g, '').trim();
  },

  getOpBadge(op) {
    const map = { create: 'create', update: 'update', delete: 'delete', create_branch: 'branch', read: 'read' };
    return map[op] || 'read';
  },

  getOpLabel(op) {
    const map = {
      create: '+ CREATE',
      update: '~ UPDATE',
      delete: '✕ DELETE',
      create_branch: '⎇ BRANCH',
      read: '▸ READ'
    };
    return map[op] || op.toUpperCase();
  }
};

// ============================================================
// ===== EXECUTION ENGINE =====
// ============================================================
const Executor = {
  async execute(plan, commitMsg) {
    const results = [];
    const ops = plan.operations || [];

    Terminal.log('exec', `Executing ${ops.length} operation(s)...`);

    for (const op of ops) {
      try {
        const result = await Executor.runOp(op, commitMsg || plan.commitMessage || 'chore: update via GitMind');
        results.push({ op, success: true, result });
        Terminal.log('ok', `✓ ${op.op} ${op.path || op.name || ''}`);
      } catch(e) {
        results.push({ op, success: false, error: e.message });
        Terminal.log('err', `✗ ${op.op} ${op.path || op.name || ''}: ${e.message}`);
        throw e; // stop on first error
      }
    }

    // Update state after execution
    await syncRepo(true);

    return results;
  },

  async runOp(op, commitMsg) {
    if (!State.githubToken) throw new Error('GitHub token not configured');
    if (!State.githubUser || !State.githubRepo) throw new Error('Repository not configured');

    switch(op.op) {
      case 'read': {
        const data = await GitHub.getFileContent(op.path);
        const content = decodeURIComponent(escape(atob(data.content.replace(/\n/g, ''))));
        return { content, sha: data.sha };
      }
      case 'create': {
        let sha;
        try {
          const existing = await GitHub.getFileContent(op.path);
          sha = existing.sha; // will update if exists
        } catch { sha = undefined; }
        return await GitHub.createOrUpdateFile(op.path, op.content || '', commitMsg, sha);
      }
      case 'update': {
        let sha;
        try {
          const existing = await GitHub.getFileContent(op.path);
          sha = existing.sha;
        } catch { sha = undefined; }
        return await GitHub.createOrUpdateFile(op.path, op.content || '', commitMsg, sha);
      }
      case 'delete': {
        const existing = await GitHub.getFileContent(op.path);
        return await GitHub.deleteFile(op.path, commitMsg, existing.sha);
      }
      case 'create_branch': {
        return await GitHub.createBranch(op.name, op.from || State.currentBranch);
      }
      default:
        throw new Error(`Unknown operation: ${op.op}`);
    }
  }
};

